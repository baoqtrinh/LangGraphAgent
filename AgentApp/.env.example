# Copy this file to .env and fill in your values.

# ── LLM (OpenAI-compatible) ──────────────────────────────────────────────────
# Point this to LM Studio, Ollama, or any OpenAI-compatible server.
LLM_ENDPOINT=http://localhost:1234/v1/chat/completions

# Optional: force a specific model name. Leave blank to use the server default.
LLM_MODEL=

# Generation temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.2

# Request timeout in seconds
LLM_TIMEOUT=60

# ── GH MCP Server ────────────────────────────────────────────────────────────
# Address of the HTTP server started by the Grasshopper plugin.
MCP_GH_ENDPOINT=http://localhost:5100
MCP_TIMEOUT=30

# ── Tavily web search (optional) ─────────────────────────────────────────────
# Only needed when the agent handles general architecture questions.
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-your-key-here
